<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<!-- HTTP listener (shelf) gelen bağlantıları kabul eder. -->
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- Cihazlara giden TCP (CLI/webhook) + mDNS browse/announce. -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- BLE eşleştirme (flutter_blue_plus). Info.plist'teki
	     NSBluetoothAlwaysUsageDescription ile birlikte gerekir. -->
	<key>com.apple.security.device.bluetooth</key>
	<true/>
	<!-- SKAPI mac scriptleri osascript ile System Events'e AppleEvent
	     gönderir (lock, dialog, media-key vb.). Sandbox'ta bu entitlement +
	     Info.plist NSAppleEventsUsageDescription gerekir; macOS ilk kullanımda
	     Automation izni sorar. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
