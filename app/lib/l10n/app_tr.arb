  "skapiScriptKillAppParamTimeoutLabel": "timeout",
  "skapiScriptKillAppParamTimeoutHint": "WM_CLOSE ile zorla sonlandırma arasında beklenecek saniye. Yüksek değerler uygulamaya kayıt için daha çok süre verir.",
  "skapiScriptKillAppParamPreKillSaveLabel": "preKillSave",
