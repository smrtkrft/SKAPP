  "skapiGroupNotifyTitle": "Notify & Dialog",
  "skapiGroupNotifyDesc": "Scripts in this group talk to the user directly: pop a toast, show a modal dialog, or wait for a yes/no answer. Use these when a SmartKraft device's event needs the human in front of the screen to acknowledge or decide.",
  "skapiGroupNotifyFoot": "Typical use: dialog before a destructive action, toast on a soft reminder, dialog with timeout to fall through automatically.",
  "skapiScriptDialogTitle": "Show Dialog",
  "skapiScriptDialogSummaryWhat": "Shows a modal Windows MessageBox and returns the user's choice (ok / cancel / yes / no / timeout).",
  "skapiScriptDialogSummaryHow": "Calls System.Windows.Forms.MessageBox on a child runspace so the script can race the dialog against an optional timeout. The chosen value is written to stdout for the caller to branch on.",
  "skapiScriptDialogNote": "stdout is the user's answer in lowercase. timeout=0 waits indefinitely.",
  "skapiScriptDialogParamTitleLabel": "title",
  "skapiScriptDialogParamTitleHint": "Window title shown in the message box.",
  "skapiScriptDialogParamBodyLabel": "body",
  "skapiScriptDialogParamBodyHint": "The question or message shown to the user.",
  "skapiScriptDialogParamButtonsLabel": "buttons",
  "skapiScriptDialogParamButtonsHint": "ok / ok_cancel / yes_no / yes_no_cancel. Default ok_cancel.",
  "skapiScriptDialogParamTimeoutLabel": "timeout",
  "skapiScriptDialogParamTimeoutHint": "Seconds to wait before falling through with 'timeout'. 0 means wait forever.",
  "skapiScriptToastTitle": "Show Toast",
  "skapiScriptToastSummaryWhat": "Shows a Windows toast notification with a title and body. Slides in from the bottom right and lands in Action Center.",
  "skapiScriptToastSummaryHow": "Builds a ToastNotification XML payload and hands it to the WinRT ToastNotificationManager under the configured AppUserModelID.",
  "skapiScriptToastNote": "Tier 2: requires Windows 10+ and a registered AppUserModelID for the cleanest UX. The default AUMID puts the toast under PowerShell in Action Center.",
  "skapiScriptToastParamTitleLabel": "title",
  "skapiScriptToastParamTitleHint": "Bold first line of the toast.",
  "skapiScriptToastParamBodyLabel": "body",
  "skapiScriptToastParamBodyHint": "Smaller second line. Optional.",
  "skapiScriptToastParamAumidLabel": "aumid",
  "skapiScriptToastParamAumidHint": "App User Model ID under which the toast appears. Default falls back to PowerShell.",
  "skapiGroupVisualBreakTitle": "Visual Break",
  "skapiGroupVisualBreakDesc": "Soft visual cues that nudge the user away from intense work: dim the screen, switch to grayscale, find the cursor, or show the desktop. Effects in this group are reversible and never hard-block input.",
  "skapiGroupVisualBreakFoot": "Typical use: dim screen at the start of a focus break, grayscale mode for late-night reads, find-mouse on multi-monitor setups.",
  "skapiScriptShowDesktopTitle": "Show Desktop",
  "skapiScriptShowDesktopSummaryWhat": "Toggles 'show desktop'. Same as pressing Win+D twice in a row.",
  "skapiScriptShowDesktopSummaryHow": "Calls Shell.Application.ToggleDesktop through COM. Running it again restores the previous window arrangement.",
  "skapiScriptFadeScreenTitle": "Fade Screen",
  "skapiScriptFadeScreenSummaryWhat": "Fades the internal display brightness from its current level to a target level over a few seconds.",
  "skapiScriptFadeScreenSummaryHow": "Reads current brightness via WMI WmiMonitorBrightness, then steps WmiSetBrightness in linear increments toward the target so the change feels smooth.",
  "skapiScriptFadeScreenNote": "Tier 2: WMI brightness only works on internal panels. External monitors do not respond on this path.",
  "skapiScriptFadeScreenParamTargetLabel": "target",
  "skapiScriptFadeScreenParamTargetHint": "Final brightness percentage (0-100).",
  "skapiScriptFadeScreenParamDurationLabel": "duration",
  "skapiScriptFadeScreenParamDurationHint": "Seconds the fade should take. The script uses ten brightness steps per second.",
  "skapiScriptGrayscaleTitle": "Grayscale Filter",
  "skapiScriptGrayscaleSummaryWhat": "Turns the Windows Color Filters grayscale mode on or off.",
  "skapiScriptGrayscaleSummaryHow": "Writes the ColorFiltering registry keys, then sends Win+Ctrl+C so Windows picks up the change live without a sign-out.",
  "skapiScriptGrayscaleNote": "Tier 2: requires Settings > Accessibility > Color filters > 'Allow the shortcut key' to be on for the live toggle to work.",
  "skapiScriptGrayscaleParamOnLabel": "on",
  "skapiScriptGrayscaleParamOnHint": "true to enable grayscale, false to turn it off.",
  "skapiScriptGrayscaleParamDurationLabel": "duration",
  "skapiScriptGrayscaleParamDurationHint": "0 means just toggle. >0 auto-reverts back to color after the given seconds. Ideal for visual breaks.",
  "skapiScriptFindMouseShakeTitle": "Find Mouse",
  "skapiScriptFindMouseShakeSummaryWhat": "Wiggles the cursor in a small circle to draw the eye to its position. The cursor returns to its starting point when the animation ends.",
  "skapiScriptFindMouseShakeSummaryHow": "Reads the current cursor position with GetCursorPos, then loops SetCursorPos around a circle of the configured radius. Useful on multi-monitor and 4K setups.",
  "skapiScriptFindMouseShakeNote": "Tier 2: SetCursorPos can be blocked by accessibility software, and behaviour varies under remote-desktop sessions.",
  "skapiScriptFindMouseShakeParamRadiusLabel": "radius",
  "skapiScriptFindMouseShakeParamRadiusHint": "Pixels the cursor travels from its origin during the loop. Bigger is more eye-catching.",
  "skapiScriptFindMouseShakeParamLoopsLabel": "loops",
  "skapiScriptFindMouseShakeParamLoopsHint": "How many full circles to draw before settling.",
  "skapiGroupProgramsTitle": "Specific Program Control",
  "skapiGroupProgramsDesc": "Targeted scripts for specific apps and browsers: graceful save+close, multi-instance shutdown, browser-wide cleanup. Handy when a SmartKraft device wants to wind a particular workflow down without nuking the whole desktop.",
  "skapiGroupProgramsFoot": "Typical use: save and close all editors before sleep, shut every browser at end-of-day, narrowed cleanup of one process family.",
  "skapiScriptCloseWithSaveTitle": "Save & Close App",
  "skapiScriptCloseWithSaveSummaryWhat": "Sends Ctrl+S to a target app to trigger its own save, waits, then closes the window gracefully.",
  "skapiScriptCloseWithSaveSummaryHow": "Focuses each running instance, sends Ctrl+S via SendKeys, waits the configured beat, then posts WM_CLOSE so the app can confirm or finish saving.",
  "skapiScriptCloseWithSaveNote": "Tier 2: relies on the app interpreting Ctrl+S as 'save'. Some chat / web apps treat it differently. Test with the apps you actually target.",
  "skapiScriptCloseWithSaveParamProcessLabel": "processName",
  "skapiScriptCloseWithSaveParamProcessHint": "Process name without .exe (winword, excel, code, photoshop). All running instances are saved and closed.",
  "skapiScriptCloseWithSaveParamWaitLabel": "wait",
  "skapiScriptCloseWithSaveParamWaitHint": "Seconds to wait between Ctrl+S and the close signal so the app finishes saving.",
  "skapiScriptCloseAllInstancesTitle": "Close All Instances",
  "skapiScriptCloseAllInstancesSummaryWhat": "Sends a graceful close to every visible window of a process. Each instance can show its own save dialog.",
  "skapiScriptCloseAllInstancesSummaryHow": "Iterates the matching processes via Get-Process and posts WM_CLOSE to each one's main window. No force fallback.",
  "skapiScriptCloseAllInstancesParamProcessLabel": "processName",
  "skapiScriptCloseAllInstancesParamProcessHint": "Process name without .exe. Matches all instances.",
  "skapiScriptBrowserCloseAllTitle": "Close All Browsers",
  "skapiScriptBrowserCloseAllSummaryWhat": "Closes every running mainstream browser (Chrome, Edge, Firefox, Brave, Vivaldi, Opera) gracefully.",
  "skapiScriptBrowserCloseAllSummaryHow": "Iterates the well-known browser process names and posts WM_CLOSE to each main window. Modern browsers preserve the session if 'restore tabs on next launch' is enabled.",
  "skapiScriptBrowserCloseAllNote": "Force-terminate is not used. To wipe the session as well, use kill-app per browser instead.",
  "skapiTierBadgeExperimental": "Experimental",
  "skapiTierBadgeExperimentalTooltip": "This script depends on a Windows API that may not be reliable across machines. Test it before relying on it.",
  "skapiTierBadgeBlocked": "Coming soon",
  "skapiTierBadgeBlockedTooltip": "This script is part of the planned library but not implemented yet.",
  "skapiGroupSaveWorkTitle": "Save Work",
  "skapiGroupSaveWorkDesc": "Scripts in this group save your open work to disk before a break or unexpected shutdown. When your SmartKraft device triggers a break, the chosen script automatically saves your file in Word, Excel, VS Code or any other editor, so even if your computer sleeps, shuts down, or runs another command, your work stays safe.",
  "skapiGroupSaveWorkFoot": "Typical use: auto-save at the start of a focus break, document backup on low-battery warning, or a one-button \"save everything\" trigger.",

  "skapiScriptSaveActiveWindowTitle": "Save Active Window",
  "skapiScriptSaveActiveWindowSummaryWhat": "Sends a virtual Ctrl+S to whichever Windows window currently has focus, triggering that application's own \"save\" behavior.",
  "skapiScriptSaveActiveWindowSummaryHow": "First it grabs the active window's handle and logs its title. Then it dispatches Ctrl+S via SendKeys. Word saves to its current path, VS Code writes the file. If a \"Save As\" dialog appears, it waits until the user manually confirms.",
  "skapiScriptSaveActiveWindowParamTimeoutLabel": "timeout",
  "skapiScriptSaveActiveWindowParamTimeoutHint": "Seconds to wait after sending the keystroke so the app has time to write the file.",
  "skapiScriptSaveActiveWindowParamVerboseLabel": "verbose",

  "skapiScriptSaveAllOpenTitle": "Save All Open Documents",
  "skapiScriptSaveAllOpenSummaryWhat": "Iterates through a whitelist of running editors and tells each one to save its open documents.",
  "skapiScriptSaveAllOpenSummaryHow": "For every whitelisted process found, it focuses the main window, sends Ctrl+S, then waits the configured per-app timeout before moving on. Apps that aren't running are skipped silently unless verbose mode is on.",
  "skapiScriptSaveAllOpenNote": "The whitelist defaults to Word, Excel, PowerPoint and VS Code. Edit the apps parameter to add your own.",
  "skapiScriptSaveAllOpenParamAppsLabel": "apps",
  "skapiScriptSaveAllOpenParamAppsHint": "Process names (without .exe) to send save to. Order matters: earlier entries are processed first.",
  "skapiScriptSaveAllOpenParamTimeoutLabel": "timeoutPerApp",
  "skapiScriptSaveAllOpenParamVerboseLabel": "verbose",

  "skapiScriptAutosaveTriggerTitle": "Trigger Auto-Save",
  "skapiScriptAutosaveTriggerSummaryWhat": "Broadcasts a Windows save command to every visible top-level window in one pass.",
  "skapiScriptAutosaveTriggerSummaryHow": "Enumerates visible windows, then sends each one a WM_COMMAND with the standard save id. Apps that listen for that message react as if you clicked their File menu's Save item. Faster than a per-window Ctrl+S, but a few apps ignore the broadcast.",
  "skapiScriptAutosaveTriggerNote": "Use this when you want to flush every editor at once and don't mind that a small number of apps may not respond. Combine with save-all-open for stricter coverage.",
  "skapiScriptAutosaveTriggerParamDelayLabel": "delay",
  "skapiScriptAutosaveTriggerParamDelayHint": "Seconds to wait before broadcasting, useful when you want the device's break notification to appear first.",
  "skapiScriptAutosaveTriggerParamVerboseLabel": "verbose",

