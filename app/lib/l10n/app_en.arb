  "skapiGroupPowerTitle": "Power Management",
  "skapiGroupPowerDesc": "Scripts in this group lock, sleep, hibernate, or shut down the computer. They are useful when a SmartKraft device signals the end of a focus session or detects extended idle time and you want the machine to follow suit.",
  "skapiGroupPowerFoot": "Typical use: lock when you stand up, hibernate at the end of the day, scheduled shutdown after a long idle period.",
  "skapiScriptLockTitle": "Lock Workstation",
  "skapiScriptLockSummaryWhat": "Locks Windows immediately and returns to the sign-in screen. Open apps keep running.",
  "skapiScriptLockSummaryHow": "Calls the user32 LockWorkStation Win32 function. Equivalent to pressing Win+L.",
  "skapiScriptHibernateTitle": "Hibernate",
  "skapiScriptHibernateSummaryWhat": "Saves the current session to disk and powers the machine down. Resuming returns to where you left off, even with no battery.",
  "skapiScriptHibernateSummaryHow": "Runs the built-in shutdown.exe with the /h flag. Hibernation must be enabled in Windows power settings; if it is not, Windows falls back to sleep.",
  "skapiScriptHibernateNote": "Run powercfg /hibernate on once from an admin shell if hibernate is missing on your system.",
  "skapiScriptHibernateParamDelayLabel": "delay",
  "skapiScriptHibernateParamDelayHint": "Seconds to wait before hibernating, in case the device's notification should appear first.",
  "skapiScriptSleepTitle": "Sleep",
  "skapiScriptSleepSummaryWhat": "Suspends the machine to RAM (S3). Resuming is fast but draws a small amount of battery while suspended.",
  "skapiScriptSleepSummaryHow": "Calls System.Windows.Forms.Application.SetSuspendState with PowerState.Suspend. The OS may delay if a foreground process is blocking idle transitions.",
  "skapiScriptSleepParamDelayLabel": "delay",
  "skapiScriptSleepParamDelayHint": "Seconds to wait before sleeping.",
  "skapiScriptShutdownTitle": "Shutdown",
  "skapiScriptShutdownSummaryWhat": "Initiates a graceful Windows shutdown. Open apps are asked to save and close.",
  "skapiScriptShutdownSummaryHow": "Runs the built-in shutdown.exe /s. With force enabled, /f is added so unresponsive apps are terminated.",
  "skapiScriptShutdownNote": "A non-zero delay gives the user time to cancel via shutdown /a from a terminal.",
  "skapiScriptShutdownParamDelayLabel": "delay",
  "skapiScriptShutdownParamDelayHint": "Seconds Windows waits before powering down. 30 is the default; pick 0 for immediate shutdown.",
  "skapiScriptShutdownParamForceLabel": "force",
  "skapiScriptShutdownParamForceHint": "Closes apps that do not respond to the shutdown signal. Unsaved work in those apps may be lost.",
  "skapiGroupDisplayAudioTitle": "Display, Image & Sound",
  "skapiGroupDisplayAudioDesc": "Scripts in this group adjust the screen and audio output: brightness, volume, mute, and media playback. They are useful when a SmartKraft device wants the computer to dim during a focus break or pause music when you stand up.",
  "skapiGroupDisplayAudioFoot": "Typical use: dim screen during a break, mute on lock, pause Spotify when a device detects no activity.",
  "skapiScriptBrightnessTitle": "Set Brightness",
  "skapiScriptBrightnessSummaryWhat": "Sets the brightness of the internal display to a percentage between 0 and 100.",
  "skapiScriptBrightnessSummaryHow": "Calls the WMI WmiMonitorBrightnessMethods.WmiSetBrightness with the requested level. Only laptops, tablets, and built-in panels respond; external DDC/CI monitors are not supported on this path.",
  "skapiScriptBrightnessNote": "External monitors will not change. For multi-monitor setups, only the panel reporting brightness through WMI reacts.",
  "skapiScriptBrightnessParamLevelLabel": "level",
  "skapiScriptBrightnessParamLevelHint": "Brightness percentage (0-100). Lower values are dimmer. 70 is a comfortable default in normal lighting.",
  "skapiScriptBrightnessParamTimeoutLabel": "timeout",
  "skapiScriptBrightnessParamTimeoutHint": "Seconds the brightness change is allowed to take. The OS smoothly ramps within this window.",
  "skapiScriptMuteToggleTitle": "Toggle Mute",
  "skapiScriptMuteToggleSummaryWhat": "Toggles the system master mute. Active media keeps playing but you do not hear it.",
  "skapiScriptMuteToggleSummaryHow": "Sends the VK_VOLUME_MUTE virtual key, the same path Windows uses when the user presses the mute key on a keyboard. No admin or COM dependency.",
  "skapiScriptMuteToggleParamModeLabel": "mode",
  "skapiScriptMuteToggleParamModeHint": "toggle / on / off. Only toggle is enforced through the simple keystroke; on and off are accepted for forward compatibility.",
  "skapiScriptVolumeSetTitle": "Set Volume",
  "skapiScriptVolumeSetSummaryWhat": "Sets the system master volume to a precise level between 0 and 100.",
  "skapiScriptVolumeSetSummaryHow": "Calls the Core Audio IAudioEndpointVolume.SetMasterVolumeLevelScalar through inline C# COM interop. Targets the default render endpoint.",
  "skapiScriptVolumeSetNote": "Tier 2: works on standard Windows 10/11 desktops. Stripped-down installs may not expose the COM interface; per-app endpoints are not addressed by this path.",
  "skapiScriptVolumeSetParamLevelLabel": "level",
  "skapiScriptVolumeSetParamLevelHint": "Volume percentage (0-100). 0 silences without setting mute; 50 is a comfortable default.",
  "skapiScriptMediaKeyTitle": "Media Key",
  "skapiScriptMediaKeySummaryWhat": "Simulates a media key press: play-pause, next, previous, or stop. Goes to whichever app currently owns the media session.",
  "skapiScriptMediaKeySummaryHow": "Sends VK_MEDIA_PLAY_PAUSE / VK_MEDIA_NEXT_TRACK / VK_MEDIA_PREV_TRACK / VK_MEDIA_STOP through keybd_event. Windows routes the press through the System Media Transport Controls.",
  "skapiScriptMediaKeyNote": "Tier 2: needs an active media session. If no app is playing or the foreground app does not register with SMTC, the press is silently dropped.",
  "skapiScriptMediaKeyParamKeyLabel": "key",
  "skapiScriptMediaKeyParamKeyHint": "play-pause / next / previous / stop. Default is play-pause.",
  "skapiGroupWindowAppTitle": "Window & Application",
  "skapiGroupWindowAppDesc": "Scripts in this group control windows and applications: minimise, focus, close gracefully, or kill processes outright. They keep your workspace tidy when a SmartKraft device wants the computer to switch context.",
  "skapiGroupWindowAppFoot": "Typical use: minimise everything when a focus session starts, close the browser when work is over, kill a stuck app on demand.",
  "skapiScriptMinimizeWindowTitle": "Minimise Window",
  "skapiScriptMinimizeWindowSummaryWhat": "Minimises a specific window by process name. Empty process name targets the currently focused window.",
  "skapiScriptMinimizeWindowSummaryHow": "Resolves the first matching main window via Get-Process and calls user32 ShowWindow with SW_MINIMIZE.",
  "skapiScriptMinimizeWindowNote": "If multiple instances are running, only the first matching window is minimised. Use the process name without the .exe suffix.",
  "skapiScriptMinimizeWindowParamProcessLabel": "processName",
  "skapiScriptMinimizeWindowParamProcessHint": "Process name without .exe (chrome, code, winword). Empty targets the foreground window.",
  "skapiScriptCloseWindowTitle": "Close Window",
  "skapiScriptCloseWindowSummaryWhat": "Sends a graceful close to a window so the app can show its own \"save changes?\" dialog.",
  "skapiScriptCloseWindowSummaryHow": "Posts WM_CLOSE through user32 SendMessage. Same effect as the user clicking the X button. Empty process name targets the foreground window.",
  "skapiScriptCloseWindowNote": "Apps with unsaved work will pop their own dialog. The script does not wait for or terminate hung apps.",
  "skapiScriptCloseWindowParamProcessLabel": "processName",
  "skapiScriptCloseWindowParamProcessHint": "Process name without .exe. Empty targets the foreground window.",
  "skapiScriptKillAppTitle": "Force Quit App",
  "skapiScriptKillAppSummaryWhat": "Terminates every instance of a process. Tries WM_CLOSE first, then TerminateProcess if the app is still alive after the timeout.",
  "skapiScriptKillAppSummaryHow": "Sends WM_CLOSE to each main window, waits the configured timeout, then issues Stop-Process with -Force on anything still running.",
  "skapiScriptKillAppNote": "Unsaved work in unresponsive apps will be lost on force-terminate. Use preKillSave for editor-style apps that respond to Ctrl+S.",
  "skapiScriptKillAppParamProcessLabel": "processName",
  "skapiScriptKillAppParamProcessHint": "Process name without .exe. All running instances are terminated.",
  "skapiScriptKillAppParamTimeoutLabel": "timeout",
  "skapiScriptKillAppParamTimeoutHint": "Seconds to wait between WM_CLOSE and force-terminate. Higher values give the app more time to save.",
  "skapiScriptKillAppParamPreKillSaveLabel": "preKillSave",
  "skapiScriptKillAppParamPreKillSaveHint": "Sends Ctrl+S to the foreground window before closing. Useful for editors but a no-op on apps that ignore Ctrl+S.",
  "skapiScriptLaunchAppTitle": "Launch App",
  "skapiScriptLaunchAppSummaryWhat": "Starts an executable, opens a URL, or launches a document with the default handler.",
  "skapiScriptLaunchAppSummaryHow": "Calls PowerShell Start-Process with the path and optional argument list. Path may be an .exe, a full file path, or a URL.",
  "skapiScriptLaunchAppNote": "Paths with spaces are accepted. Use a URL like https://example.com to open the default browser.",
  "skapiScriptLaunchAppParamPathLabel": "path",
  "skapiScriptLaunchAppParamPathHint": "Executable, full file path, or URL. notepad / C:\\\\tools\\\\my.exe / https://example.com.",
  "skapiScriptLaunchAppParamArgsLabel": "args",
  "skapiScriptLaunchAppParamArgsHint": "Arguments passed to the executable. Empty for none.",
