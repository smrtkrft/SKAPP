<?xml version="1.0" encoding="utf-8"?>
<!--
  USB device filter for SKAPP — referenced from AndroidManifest.xml's
  USB_DEVICE_ATTACHED meta-data. Listed VID/PID pairs cause the OS to
  offer SKAPP as one of the apps to handle the attached device.

  ESP32-C6 native USB-Serial/JTAG (VID 0x303a / PID 0x1001) — the BF
  reference board ships with this. Decimal values used because Android
  resource parser does not accept hex literals here.
    0x303a = 12346
    0x1001 = 4097
-->
<resources>
    <usb-device vendor-id="12346" product-id="4097" />
</resources>
