<?xml version="1.0" encoding="utf-8"?>
<!-- Dark mode native splash — siyah zemin + beyaz logo. Light mode için
     drawable/launch_background.xml beyaz zemin + siyah logo gösterir;
     Android sistem mode'una göre Doğru variant'ı seçer. -->
