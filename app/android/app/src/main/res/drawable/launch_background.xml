<?xml version="1.0" encoding="utf-8"?>
<!-- Native splash — Flutter çerçevesi yüklenmeden önce gösterilir.
     Beyaz zemin + ortada siyah SKAPP logosu. Cihaz dark mode'da olsa
     bile sabit kalır (marka kimliği). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/white" />
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/skapp_logo" />
    </item>
</layer-list>
